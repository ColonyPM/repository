# --- Django ---
DEBUG=0
SECRET_KEY=change-me-on-server
DJANGO_ALLOWED_HOSTS=yourdomain.com,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# --- GitHub OAuth ---
GH_CLIENT_ID=your-gh-client-id
GH_CLIENT_SECRET=your-gh-client-secret

# --- Entrypoint ---
RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1

# --- Postgres ---
POSTGRES_DB=app_prod
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
